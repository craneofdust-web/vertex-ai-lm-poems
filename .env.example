# Required
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
POEMS_SOURCE_FOLDER=./sample_poems
VERTEX_MODEL_CANDIDATES=gemini-3.1,gemini-3-pro,gemini-2.5-pro

# Runtime defaults
MAX_STAGE_JUMP=2

# Optional generation tuning
SAMPLE_SIZE=50
MIN_ITERATIONS=30
MAX_ITERATIONS=36
TARGET_MIN_COVERAGE=3
TEMPERATURE=0.92
MAX_RETRIES=3
BASE_RETRY_SECONDS=2

# Optional fill tuning
FILL_TEMPERATURE=0.12
FILL_MAX_RETRIES=3
FILL_BASE_RETRY_SECONDS=2
FILL_TOP_K=3
FILL_BATCH_SIZE=8
FILL_MAX_POEM_CHARS=1800
ALLOW_HEURISTIC_FALLBACK=1

# Optional auth path (if not using ADC)
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
